NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk authentication.
# Create these in Clerk or install Clerk through Vercel Marketplace.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/start
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/start

# Public feedback form -> private GitHub issue.
# Token should have the minimum permission needed to create, label, and comment on issues in this repository.
GITHUB_FEEDBACK_TOKEN=
GITHUB_FEEDBACK_REPO=lspassos1/aframe-kingspan-local

# Comma-separated Clerk account emails allowed to approve/reject feedback in /admin/feedback.
ADMIN_EMAILS=
