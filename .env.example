NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk authentication.
# Create these in Clerk or install Clerk through Vercel Marketplace.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/start
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/start

# Public feedback form -> private GitHub issue.
# Token should have the minimum permission needed to create, label, and comment on issues in this repository.
GITHUB_FEEDBACK_TOKEN=
GITHUB_FEEDBACK_REPO=lspassos1/aframe-kingspan-local

# Slack slash command -> GitHub Lucas Review comments.
# Server-side only. Never expose these as NEXT_PUBLIC_*.
SLACK_SIGNING_SECRET=
SLACK_ALLOWED_USER_IDS=
SLACK_ALLOWED_CHANNEL_IDS=
GITHUB_REVIEW_TOKEN=
GITHUB_REVIEW_REPO=lspassos1/aframe-kingspan-local

# GitHub Actions hourly issue/PR triage -> Slack incoming webhook.
# Configure this as a GitHub Actions repository secret, not as NEXT_PUBLIC_*.
SLACK_TRIAGE_WEBHOOK_URL=

# Comma-separated Clerk account emails allowed to approve/reject feedback in /admin/feedback.
ADMIN_EMAILS=

# ------ AI plan extraction ------
# Server-side only. Never expose these as NEXT_PUBLIC_*.
AI_PLAN_EXTRACT_ENABLED=false
AI_PLAN_EXTRACT_DAILY_LIMIT_PER_USER=3
AI_PLAN_EXTRACT_DAILY_LIMIT_PER_IP=5
AI_PLAN_EXTRACT_GLOBAL_DAILY_LIMIT=50
AI_PLAN_EXTRACT_MAX_FILE_MB=8
AI_PLAN_EXTRACT_CACHE_TTL_HOURS=24
# Optional manual bust when prompt/model/base assumptions change.
AI_PLAN_EXTRACT_CACHE_VERSION=
AI_PLAN_EXTRACT_PROVIDER_ORDER=openai
AI_ALLOW_ANONYMOUS_PLAN_EXTRACT=false
# Required in production. Use a strong secret, not the example value.
AI_RATE_LIMIT_SALT=change-me-in-production
AI_RATE_LIMIT_FAIL_OPEN=false
AI_RATE_LIMIT_REDIS_TIMEOUT_MS=2500
# Trust x-forwarded-for/x-real-ip only behind a proxy you control.
AI_TRUST_PROXY_IP_HEADERS=false

# ------ AI routing policy ------
# Free-cloud routing for plan extraction.
# Gemini is the primary extractor; OpenRouter is optional for second review.
# Server-side only. Never expose provider keys as NEXT_PUBLIC_*.
AI_MODE=free-cloud
AI_PAID_FALLBACK_ENABLED=false
AI_PLAN_PRIMARY_PROVIDER=gemini
AI_PLAN_REVIEW_PROVIDER=openrouter
AI_TEXT_PROVIDER=groq
AI_TEXT_FALLBACK_PROVIDER=cerebras

# Free-cloud provider keys.
# Configure only on the server/Vercel environment where the mode is enabled.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FREE_TIER_NOTICE=true
OPENROUTER_API_KEY=
OPENROUTER_PLAN_REVIEW_MODEL=google/gemini-2.0-flash-exp:free
GROQ_API_KEY=
GROQ_TEXT_MODEL=
CEREBRAS_API_KEY=
CEREBRAS_TEXT_MODEL=
SAMBANOVA_API_KEY=
SAMBANOVA_TEXT_MODEL=

# OpenAI provider.
# Server-side only. Never create NEXT_PUBLIC_OPENAI_API_KEY.
# Kept in standby for explicit paid mode or AI_PAID_FALLBACK_ENABLED=true.
OPENAI_API_KEY=
AI_OPENAI_MODEL=gpt-4o-mini

# Optional production rate limit storage.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
